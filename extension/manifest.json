{
  "manifest_version": 3,
  "name": "Mars Browser Bridge",
  "description": "Local-first MCP bridge for controlling selected Chrome tabs with explicit user approval.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "action": {
    "default_title": "Mars Browser Bridge",
    "default_popup": "pages/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_page": "pages/options.html",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "nativeMessaging",
    "activeTab",
    "sidePanel"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/*.html",
        "styles/*.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
